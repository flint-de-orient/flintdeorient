# Copy this file to ".env" and fill in real values.

# The Gmail account that sends the emails.
GMAIL_USER=common.fdo@gmail.com

# Gmail APP PASSWORD (NOT your normal Gmail password).
# Generate at: https://myaccount.google.com/apppasswords (needs 2-Step Verification ON).
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Where new lead notifications are delivered (defaults to GMAIL_USER if blank).
ADMIN_EMAIL=common.fdo@gmail.com

# Used for the "Visit Our Website" button in the confirmation email.
WEBSITE_URL=https://flintdeorient.com

# Logo shown at the top of the emails.
# - Leave BLANK to embed the logo inline (shows as a "logo.png" attachment).
# - Paste a hosted image URL (e.g. Cloudinary) to remove the attachment entirely.
LOGO_URL=

# Port the contact API runs on (must match the proxy in vite.config.ts).
PORT=3001
